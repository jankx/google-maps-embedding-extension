{
    "name": "jankx/google-maps-embed",
    "title": "Google Maps (Embed)",
    "category": "jankx",
    "icon": "share-alt2",
    "description": "Embed a Google Map using the standard iframe embed code.",
    "keywords": [
        "google",
        "map",
        "iframe",
        "embed"
    ],
    "attributes": {
        "embedCode": {
            "type": "string",
            "default": ""
        },
        "height": {
            "type": "string",
            "default": "450px"
        },
        "aspectRatio": {
            "type": "string",
            "default": "16/9"
        }
    },
    "example": {
        "attributes": {
            "embedCode": "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3724.095333145151!2d105.84813357602016!3d21.028882080620573!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3135ab953357c963%3A0x1c7162968866aa9e!2zSOG7kyBIb8OgbiBLaGnhur9t!5e0!3m2!1svi!2s!4v1717677000000!5m2!1svi!2s",
            "aspectRatio": "16/9"
        }
    },
    "supports": {
        "align": [
            "wide",
            "full"
        ]
    },
    "editorScript": "file:../../dist/index.js"
}